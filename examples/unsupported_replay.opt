-- Appendix B negative: OBS-701 witness (replay query method deferred in v0)
data Entities {
    healths: SoA<f32>,
}

optic HealthView: GradedOptic<Entities, f32, CacheGrade<2>> {
    get  s      => s.healths[s.id]
    put  (s, v) => { s.healths[s.id] = v }
}

fn main() {
    entities.query(HealthView).replay("checkpoint").map(|h| h);
}