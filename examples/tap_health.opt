-- M8 observability tap scaffolding (tap + map query, comment hook only in v0)
data Entities {
    healths: SoA<f32>,
    positions: SoA<Vec2>,
}

optic HealthView: GradedOptic<Entities, f32, CacheGrade<2> + AffineGrade> {
    get  s      => s.healths[s.id]
    put  (s, v) => { s.healths[s.id] = v }
}

fn main() {
    entities.query(HealthView).tap("health_probe").map(|h| h - 10.0);
}