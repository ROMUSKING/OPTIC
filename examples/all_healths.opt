-- M7 traversal map decay (GradedTraversal + get/put v0 surface)
data Entities {
    healths: SoA<f32>,
}

optic AllHealths: GradedTraversal<Entities, f32, CacheGrade<2>> {
    get  s      => s.healths[s.id]
    put  (s, v) => { s.healths[s.id] = v }
}

fn main() {
    entities.query(AllHealths).map(|h| h - 10.0);
}